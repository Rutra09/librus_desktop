import { Theme } from "style.slint";
import { VerticalBox, HorizontalBox, Button } from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";



export component Sidebar inherits Rectangle {
    in property <int> active-page;
    in property <string> user-name;
    in property <string> lucky-number;
    
    callback navigate(int);
    callback logout();
    callback refresh();
    
    background: #18181b; // zinc-900 hex
    width: 250px; // w-64
    height: 100%; // h-screen
    
    VerticalBox {
        padding: Theme.padding;
        spacing: Theme.gap;
        
        // Header
        VerticalBox {
            spacing: 4px;
            Text {
                text: "Librus";
                font-size: 24px;
                font-weight: 700;
                color: #3b82f6; // blue-500
            }
            Text {
                text: "Witaj, " + root.user-name;
                font-size: 12px;
                color: #a1a1aa; // zinc-400
            }
        }
        
        Rectangle { height: 1px; background: #27272a; } // border-zinc-800
        
        // Navigation
        VerticalBox {
            alignment: start;
            spacing: 4px;
            
            Rectangle {
                height: 40px; background: root.active-page == 1 ? Theme.primary : transparent; border-radius: Theme.radius;
                TouchArea {
                    clicked => { root.navigate(1); }
                    HorizontalBox {
                        padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                        Rectangle { width: 20px; IconDisplay { icon: IconSet.LayoutDashboard; size: 20px; stroke-width: 2.3; stroke: root.active-page == 1 ? Theme.primary-foreground : Theme.muted-foreground; y: (parent.height - self.height) / 2; } }
                        Text { text: "Dashboard"; font-size: 14px; color: root.active-page == 1 ? Theme.primary-foreground : Theme.muted-foreground; vertical-alignment: center; }
                    }
                }
            }
            Rectangle {
                height: 40px; background: root.active-page == 2 ? Theme.primary : transparent; border-radius: Theme.radius;
                TouchArea {
                    clicked => { root.navigate(2); }
                    HorizontalBox {
                        padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                        Rectangle { width: 20px; IconDisplay { icon: IconSet.CalendarDays; size: 20px; stroke-width: 2.3; stroke: root.active-page == 2 ? Theme.primary-foreground : Theme.muted-foreground; y: (parent.height - self.height) / 2; } }
                        Text { text: "Plan zajęć"; font-size: 14px; color: root.active-page == 2 ? Theme.primary-foreground : Theme.muted-foreground; vertical-alignment: center; }
                    }
                }
            }
            Rectangle {
                height: 40px; background: root.active-page == 3 ? Theme.primary : transparent; border-radius: Theme.radius;
                TouchArea {
                    clicked => { root.navigate(3); }
                    HorizontalBox {
                        padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                        Rectangle { width: 20px; IconDisplay { icon: IconSet.GraduationCap; size: 20px; stroke-width: 2.3; stroke: root.active-page == 3 ? Theme.primary-foreground : Theme.muted-foreground; y: (parent.height - self.height) / 2; } }
                        Text { text: "Oceny"; font-size: 14px; color: root.active-page == 3 ? Theme.primary-foreground : Theme.muted-foreground; vertical-alignment: center; }
                    }
                }
            }
            Rectangle {
                height: 40px; background: root.active-page == 4 ? Theme.primary : transparent; border-radius: Theme.radius;
                TouchArea {
                    clicked => { root.navigate(4); }
                    HorizontalBox {
                        padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                        Rectangle { width: 20px; IconDisplay { icon: IconSet.Bell; size: 20px; stroke-width: 2.3; stroke: root.active-page == 4 ? Theme.primary-foreground : Theme.muted-foreground; y: (parent.height - self.height) / 2; } }
                        Text { text: "Ogłoszenia"; font-size: 14px; color: root.active-page == 4 ? Theme.primary-foreground : Theme.muted-foreground; vertical-alignment: center; }
                    }
                }
            }
            Rectangle {
                height: 40px; background: root.active-page == 5 ? Theme.primary : transparent; border-radius: Theme.radius;
                TouchArea {
                    clicked => { root.navigate(5); }
                    HorizontalBox {
                        padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                        Rectangle { width: 20px; IconDisplay { icon: IconSet.ClipboardList; size: 20px; stroke-width: 2.3; stroke: root.active-page == 5 ? Theme.primary-foreground : Theme.muted-foreground; y: (parent.height - self.height) / 2; } }
                        Text { text: "Frekwencja"; font-size: 14px; color: root.active-page == 5 ? Theme.primary-foreground : Theme.muted-foreground; vertical-alignment: center; }
                    }
                }
            }
            Rectangle {
                height: 40px; background: root.active-page == 6 ? Theme.primary : transparent; border-radius: Theme.radius;
                TouchArea {
                    clicked => { root.navigate(6); }
                    HorizontalBox {
                        padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                        Rectangle { width: 20px; IconDisplay { icon: IconSet.Mail; size: 20px; stroke-width: 2.3; stroke: root.active-page == 6 ? Theme.primary-foreground : Theme.muted-foreground; y: (parent.height - self.height) / 2; } }
                        Text { text: "Wiadomości"; font-size: 14px; color: root.active-page == 6 ? Theme.primary-foreground : Theme.muted-foreground; vertical-alignment: center; }
                    }
                }
            }
            Rectangle {
                height: 40px; background: root.active-page == 7 ? Theme.primary : transparent; border-radius: Theme.radius;
                TouchArea {
                    clicked => { root.navigate(7); }
                    HorizontalBox {
                        padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                        Rectangle { width: 20px; IconDisplay { icon: IconSet.StickyNote; size: 20px; stroke-width: 2.3; stroke: root.active-page == 7 ? Theme.primary-foreground : Theme.muted-foreground; y: (parent.height - self.height) / 2; } }
                        Text { text: "Zadania domowe"; font-size: 14px; color: root.active-page == 7 ? Theme.primary-foreground : Theme.muted-foreground; vertical-alignment: center; }
                    }
                }
            }
        }
        
        Rectangle { vertical-stretch: 1; } // Spacer
        
        // Footer (Lucky Number & Logout)
        Rectangle { height: 1px; background: #27272a; }

        VerticalBox {
            spacing: 8px;
            
            // Lucky Number Card
            Rectangle {
                background: #27272a; // zinc-800/50
                border-radius: Theme.radius;
                VerticalBox {
                    padding: 12px;
                    Text {
                        text: "Szczęśliwy numer";
                        font-size: 10px;
                        color: #71717a; // zinc-500
                    }
                    Text {
                        text: root.lucky-number;
                        font-size: 20px;
                        font-weight: 700;
                        color: #3b82f6;
                    }
                }
            }
            
            Button {
                text: "Odśwież dane";
                clicked => { root.refresh(); }
            }

            Button {
                text: "Wyloguj";
                clicked => { root.logout(); }
            }
        }
    }
}
