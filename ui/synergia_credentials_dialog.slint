import { Theme } from "style.slint";
import { LineEdit, Button } from "std-widgets.slint";

// Dialog for collecting Synergia credentials for messages access
export component SynergiaCredentialsDialog inherits Rectangle {
    in-out property <bool> show: false;
    callback submit(string, string);  // username, password
    callback skip();
    
    // State
    property <string> username: "";
    property <string> password: "";
    
    if show: Rectangle {
        // Overlay - fill entire window
        width: root.width;
        height: root.height;
        background: #00000080;
        
        // Center modal
        Rectangle {
            width: 400px;
            height: 340px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.card;
            border-radius: 12px;
            
            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                
                Text {
                    text: "Konfiguracja Wiadomości";
                    font-size: 20px;
                    font-weight: 700;
                    color: Theme.foreground;
                }
                
                Text {
                    text: "Aby używać wiadomości, potrzebujemy Twojego loginu i hasła Synergia.";
                    font-size: 14px;
                    color: Theme.muted-foreground;
                    wrap: word-wrap;
                }
                
                // Username
                Text {
                    text: "Login Synergia (np. 1234567u):";
                    font-size: 12px;
                    color: Theme.foreground;
                }
                
                LineEdit {
                    text <=> username;
                   font-size: 14px;
                    height: 40px;
                }
                
                // Password
                Text {
                    text: "Hasło Synergia:";
                    font-size: 12px;
                    color: Theme.foreground;
                }
                
                LineEdit {
                    text <=> password;
                    input-type: InputType.password;
                    font-size: 14px;
                    height: 40px;
                }
                
                Rectangle {
                    height: 10px;
                }
                
                // Buttons
                HorizontalLayout {
                    spacing: 12px;
                    
                    Button {
                        text: "Pomiń";
                        clicked => {
                            root.skip();
                        }
                    }
                    
                    Button {
                        text: "Zapisz";
                        primary: true;
                        enabled: username != "" && password != "";
                        clicked => {
                            root.submit(username, password);
                            username = "";
                            password = "";
                        }
                    }
                }
            }
        }
    }
}
