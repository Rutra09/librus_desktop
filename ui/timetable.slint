import { VerticalBox, HorizontalBox, Button, ScrollView } from "std-widgets.slint";
import { Theme } from "style.slint";
import { IconDisplay, IconSet } from "@lucide";

// ── Data model ──────────────────────────────────────────────────────────

export struct UIGridCell {
    has-lesson: bool,
    subject: string,
    teacher: string,
    room: string,
    hour-from: string,
    hour-to: string,
    lesson-type: int,       // 0=normal, 1=cancelled, 2=change, 3=shifted_source, 4=shifted_target
    event-content: string,
    event-category: string,
    change-info: string,
}

export struct UIGridRow {
    no: int,
    hour-from: string,
    hour-to: string,
    cells: [UIGridCell],
}

export struct UILesson {
    id: int,
    no: int,
    subject: string,
    teacher: string,
    room: string,
    color: brush,
    is-substitution: bool,
    is-canceled: bool,
    hour-from: string,
    hour-to: string,
    event-content: string,
    event-category: string,
    substitution-desc: string,
}

export struct UIDay {
    date: string,
    name: string,
    lessons: [UILesson],
}

// ── Popover ─────────────────────────────────────────────────────────────

component LessonPopover inherits Rectangle {
    in property <bool> open;
    in property <UIGridCell> cell;
    callback close;
    visible: open;

    TouchArea { width: 100%; height: 100%; clicked => { root.close(); } }
    Rectangle { background: #00000080; width: 100%; height: 100%; }

    Rectangle {
        width: 380px;
        height: 420px;
        background: Theme.popover;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.border;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        opacity: open ? 1.0 : 0.0;
        animate opacity { duration: 200ms; easing: ease-out; }

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;
            alignment: start;

            Text { text: "Szczegóły lekcji"; font-size: 12px; color: Theme.muted-foreground; }

            Text {
                text: root.cell.subject;
                font-size: 22px;
                font-weight: 700;
                color: Theme.foreground;
                wrap: word-wrap;
            }

            if root.cell.lesson-type == 1 || root.cell.lesson-type == 3 : Rectangle {
                background: #991b1b; border-radius: 6px; height: 26px; vertical-stretch: 0;
                HorizontalLayout {
                    spacing: 4px; alignment: center; padding-left: 8px; padding-right: 8px;
                    Rectangle { 
                        width: 14px; 
                        IconDisplay { icon: root.cell.lesson-type == 1 ? IconSet.Ban : IconSet.ArrowRightLeft; size: 14px; stroke-width: 2.3; stroke: #fca5a5; y: (parent.height - self.height) / 2; }
                    }
                    Text {
                        text: root.cell.lesson-type == 1 ? "Odwołane" : "Przeniesione (źródło)";
                        font-size: 11px; font-weight: 600; color: #fca5a5;
                        vertical-alignment: center;
                    }
                }
            }

            if root.cell.lesson-type == 2 || root.cell.lesson-type == 4 : Rectangle {
                background: #92400e; border-radius: 6px; height: 26px; vertical-stretch: 0;
                HorizontalLayout {
                    spacing: 4px; alignment: center; padding-left: 8px; padding-right: 8px;
                    Rectangle { 
                        width: 14px;
                        IconDisplay { icon: root.cell.lesson-type == 2 ? IconSet.UserRoundPen : IconSet.ArrowRightLeft; size: 14px; stroke-width: 2.3; stroke: #fcd34d; y: (parent.height - self.height) / 2;}
                    }
                    Text {
                        text: root.cell.lesson-type == 2 ? "Zastępstwo" : "Przeniesione (cel)";
                        font-size: 11px; font-weight: 600; color: #fcd34d;
                        vertical-alignment: center;
                    }
                }
            }

            if root.cell.change-info != "" : Text {
                text: root.cell.change-info;
                font-size: 12px; color: Theme.muted-foreground; wrap: word-wrap;
            }

            if root.cell.event-content != "" : Rectangle {
                background: #1e3a5f; border-radius: 8px;
                height: evt-lay.preferred-height + 16px; vertical-stretch: 0;
                evt-lay := VerticalBox {
                    padding: 10px; spacing: 4px;
                    Text { text: root.cell.event-category != "" ? root.cell.event-category : "Wydarzenie"; font-weight: 600; font-size: 11px; color: #93c5fd; }
                    Text { text: root.cell.event-content; color: Theme.foreground; font-size: 13px; wrap: word-wrap; }
                }
            }

            Rectangle { height: 1px; background: Theme.border; vertical-stretch: 0; }

            VerticalBox {
                spacing: 6px; padding: 0px;
                Text { text: root.cell.hour-from + " – " + root.cell.hour-to; color: Theme.muted-foreground; font-size: 13px; }
                Text { text: "Nauczyciel: " + root.cell.teacher; color: Theme.muted-foreground; font-size: 13px; wrap: word-wrap; }
                Text { text: "Sala: " + root.cell.room; color: Theme.muted-foreground; font-size: 13px; }
            }

            Rectangle { vertical-stretch: 1; }
            Button { text: "Zamknij"; clicked => { root.close(); } }
        }
    }
}

// ── Grid Cell ───────────────────────────────────────────────────────────

component GridCell inherits Rectangle {
    in property <UIGridCell> cell;
    in property <bool> is-today: false;
    callback clicked;

    // Height naturally flows from parent's HorizontalBox stretch 
    border-width: 0px;

    background: !cell.has-lesson
        ? (is-today ? #ffffff08 : Theme.background)
        : cell.lesson-type == 1 ? #7f1d1d28
        : cell.lesson-type == 3 ? #7f1d1d28
        : cell.lesson-type == 2 ? #854d0e28
        : cell.lesson-type == 4 ? #854d0e28
        : (is-today ? #ffffff0c : Theme.card);

    ta := TouchArea {
        enabled: cell.has-lesson;
        clicked => { root.clicked(); }
        mouse-cursor: cell.has-lesson ? pointer : default;
    }

    Rectangle {
        visible: ta.has-hover && cell.has-lesson;
        background: #ffffff0a;
    }

    // Unconditional block ensures background stretches properly 
    VerticalBox {
        visible: cell.has-lesson;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 2px;
        alignment: start;

        // Status badge
        if cell.lesson-type == 1 || cell.lesson-type == 3 : HorizontalBox {
            spacing: 0px; vertical-stretch: 0; alignment: start;
            Rectangle {
                background: #991b1b;
                border-radius: 3px;
                height: 16px;
                width: badge-txt.preferred-width + 12px;
                vertical-stretch: 0;
                badge-txt := Text {
                    text: cell.lesson-type == 1 ? "odwołane" : "przeniesione";
                    font-size: 9px; font-weight: 700; color: #fca5a5;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }

        // Subject - allow wrapping so row scales
        Text {
            text: cell.subject;
            font-weight: 700;
            font-size: 13px;
            color: (cell.lesson-type == 1 || cell.lesson-type == 3) ? #777 : Theme.foreground;
            wrap: word-wrap;
        }

        // Teacher - allow wrapping
        Text {
            text: cell.teacher;
            font-size: 10px;
            color: #777;
            wrap: word-wrap;
        }

        // Room tag
        if cell.room != "" && cell.room != "-" : HorizontalBox {
            spacing: 0px; vertical-stretch: 0; alignment: start;
            Rectangle {
                background: #ffffff10;
                border-radius: 3px;
                height: 17px;
                width: room-t.preferred-width + 12px;
                vertical-stretch: 0;
                room-t := Text {
                    text: "s. " + cell.room;
                    font-size: 9px; font-weight: 500; color: #999;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }

        // Change info - allow wrapping
        if cell.change-info != "" : HorizontalBox {
            padding: 0px; spacing: 4px; alignment: start;
            Rectangle {
                width: 10px;
                IconDisplay { icon: IconSet.CornerDownRight; size: 10px; stroke-width: 2.0; stroke: (cell.lesson-type == 2 || cell.lesson-type == 4) ? #fbbf24 : #f87171; y: 2px;}
            }
            Text {
                text: cell.change-info;
                font-size: 9px;
                color: (cell.lesson-type == 2 || cell.lesson-type == 4) ? #fbbf24 : #f87171;
                wrap: word-wrap;
            }
        }

        // Event indicator
        if cell.event-content != "" : HorizontalBox {
            spacing: 0px; vertical-stretch: 0; alignment: start;
            Rectangle {
                background: #2563eb;
                border-radius: 3px;
                height: 14px; width: 14px; vertical-stretch: 0;
                Text { text: "!"; color: white; font-weight: 700; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}

// ── Main View ───────────────────────────────────────────────────────────

export component TimetableView inherits Rectangle {
    in property <[UIGridRow]> grid-rows;
    in property <[string]> day-headers;
    in property <string> week-range: "Ładowanie...";
    in property <int> today-col-index: -1;
    callback prev-week();
    callback next-week();

    background: Theme.background;

    property <bool> overlay-open: false;
    property <UIGridCell> selected-cell;

    property <length> nr-col-width: 24px;
    property <length> hour-col-width: 52px;
    property <length> day-col-width: (root.width - nr-col-width - hour-col-width) / max(1, root.day-headers.length);

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Week navigation
        HorizontalBox {
            alignment: center;
            spacing: 8px;
            vertical-stretch: 0;
            height: 36px;
            Rectangle {
                width: 36px; height: 24px;
                background: ta1.pressed ? Theme.secondary : transparent;
                border-radius: Theme.radius;
                ta1 := TouchArea {
                    clicked => { root.prev-week(); }
                    HorizontalBox {
                        alignment: center; vertical-stretch: 1; horizontal-stretch: 1; padding: 0px; spacing: 0px;
                        IconDisplay { icon: IconSet.ChevronLeft; size: 16px; stroke-width: 2.3; stroke: Theme.foreground; }
                    }
                }
            }
            Text {
                text: root.week-range;
                font-size: 16px;
                font-weight: 600;
                color: Theme.foreground;
                vertical-alignment: center;
            }
            Rectangle {
                width: 36px; height: 24px;
                background: ta2.pressed ? Theme.secondary : transparent;
                border-radius: Theme.radius;
                ta2 := TouchArea {
                    clicked => { root.next-week(); }
                    HorizontalBox {
                        alignment: center; vertical-stretch: 1; horizontal-stretch: 1; padding: 0px; spacing: 0px;
                        IconDisplay { icon: IconSet.ChevronRight; size: 16px; stroke-width: 2.3; stroke: Theme.foreground; }
                    }
                }
            }
        }

        // Grid
        ScrollView {
            VerticalBox {
                spacing: 0px;
                padding: 0px;
                alignment: start;

                // Header row
                HorizontalBox {
                    spacing: 0px;
                    padding: 0px;
                    vertical-stretch: 0;

                    Rectangle {
                        width: nr-col-width; height: 26px;
                        background: Theme.muted; border-width: 0px;
                        horizontal-stretch: 0;
                        Text { text: "Nr"; font-size: 10px; font-weight: 600; color: Theme.muted-foreground; horizontal-alignment: center; vertical-alignment: center; }
                    }

                    Rectangle {
                        width: hour-col-width; height: 26px;
                        background: Theme.muted; border-width: 0px;
                        horizontal-stretch: 0;
                        Text { text: "Godz."; font-size: 10px; font-weight: 600; color: Theme.muted-foreground; horizontal-alignment: center; vertical-alignment: center; }
                    }

                    for day[idx] in root.day-headers : Rectangle {
                        height: 26px;
                        width: day-col-width;
                        background: idx == root.today-col-index ? #ffffff12 : Theme.muted;
                        border-width: 0px;
                        if idx == root.today-col-index : Rectangle {
                            y: parent.height - 2px;
                            height: 2px;
                            background: #3b82f6;
                        }
                        Text {
                            text: day;
                            font-size: 10px;
                            font-weight: idx == root.today-col-index ? 700 : 600;
                            color: idx == root.today-col-index ? #93c5fd : Theme.muted-foreground;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Body rows
                for row in root.grid-rows : HorizontalBox {
                    spacing: 0px;
                    padding: 0px;
                    vertical-stretch: 0;
                    min-height: 62px;

                    Rectangle {
                        width: nr-col-width; 
                        background: Theme.muted; border-width: 0px;
                        horizontal-stretch: 0;
                        Text { text: row.no; font-size: 11px; font-weight: 600; color: Theme.muted-foreground; horizontal-alignment: center; vertical-alignment: center; }
                    }

                    Rectangle {
                        width: hour-col-width; 
                        background: Theme.muted; border-width: 0px;
                        horizontal-stretch: 0;
                        VerticalBox {
                            alignment: center; padding: 2px; spacing: 0px;
                            Text { text: row.hour-from; font-size: 10px; font-weight: 500; color: Theme.muted-foreground; horizontal-alignment: center; }
                            Text { text: row.hour-to; font-size: 9px; color: #666; horizontal-alignment: center; }
                        }
                    }

                    for cell[idx] in row.cells : GridCell {
                        cell: cell;
                        is-today: idx == root.today-col-index;
                        width: day-col-width;
                        clicked => {
                            root.selected-cell = cell;
                            root.overlay-open = true;
                        }
                    }
                }
            }
        }
    }

    LessonPopover {
        open: root.overlay-open;
        cell: root.selected-cell;
        close => { root.overlay-open = false; }
    }
}
