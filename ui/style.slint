export global Theme {
    // Dark Theme (Matches .dark in theme.css)
    out property <color> background: #252525; // oklch(0.145 0 0)
    out property <color> foreground: #fcfcfc; // oklch(0.985 0 0)
    out property <color> card: #2e2e2e; // darker card
    out property <color> card-foreground: #fcfcfc;
    out property <color> popover: #252525;
    out property <color> popover-foreground: #fcfcfc;
    out property <color> primary: #ececec; // oklch(0.985 0 0)
    out property <color> primary-foreground: #333333; // oklch(0.205 0 0)
    out property <color> secondary: #3f3f3f; // oklch(0.269 0 0)
    out property <color> secondary-foreground: #fcfcfc;
    out property <color> muted: #3f3f3f;
    out property <color> muted-foreground: #a1a1aa; // oklch(0.708 0 0)
    out property <color> accent: #3f3f3f;
    out property <color> accent-foreground: #fcfcfc;
    out property <color> destructive: #7f1d1d; // manual dark red
    out property <color> destructive-foreground: #fcfcfc;
    out property <color> border: #3f3f3f;
    out property <color> input: #3f3f3f;
    out property <color> ring: #6b7280; // oklch(0.439 0 0)
    
    out property <length> radius: 10px;
    out property <length> padding: 16px;
    out property <length> gap: 12px;
}
