import { VerticalBox, HorizontalBox, ScrollView, Button } from "std-widgets.slint";
import { Theme } from "style.slint";

export struct UIAnnouncement {
    subject: string,
    content: string,
    author: string,
    date: string,
}

component AnnouncementItem inherits Rectangle {
    in property <UIAnnouncement> item;
    
    background: Theme.card;
    border-radius: Theme.radius;
    border-width: 1px;
    border-color: Theme.border;
    
    VerticalBox {
        padding: Theme.padding;
        spacing: 8px;
        
        HorizontalBox {
            Text {
                text: item.subject;
                font-weight: 700;
                font-size: 16px;
                color: Theme.foreground;
                wrap: word-wrap;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: item.date;
                font-size: 12px;
                color: Theme.muted-foreground;
            }
        }
        
        Text {
            text: item.content;
            wrap: word-wrap;
            font-size: 14px;
            color: Theme.foreground;
        }
        
        HorizontalBox {
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: "Dodał: " + item.author;
                font-size: 12px;
                color: Theme.muted-foreground;
                font-italic: true;
            }
        }
    }
}

export component AnnouncementsView inherits Rectangle {
    in property <[UIAnnouncement]> notices;
    callback back();

    background: Theme.background;

    VerticalBox {
        padding: Theme.padding;
        spacing: Theme.gap;

        Text {
            text: "Ogłoszenia";
            font-size: 24px;
            font-weight: 700;
            color: Theme.foreground;
        }

        ScrollView {
            VerticalBox {
                spacing: Theme.gap;
                for notice in notices : AnnouncementItem {
                    item: notice;
                }
            }
        }
    }
}
